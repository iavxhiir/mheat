{
  "name": "MHEAT",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [8000, 5173, 4173],
  "portsAttributes": {
    "8000": {"label": "MHEAT API", "onAutoForward": "openPreview"},
    "5173": {"label": "Vite dev server"},
    "4173": {"label": "Vite preview"}
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y --no-install-recommends libgeos-dev libproj-dev libspatialindex-dev && pip install --upgrade pip && pip install -r backend/requirements-dev.txt && npm --prefix frontend install --no-audit --no-fund",
  "postStartCommand": "python scripts/run_all.py --only env-check",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-vscode.makefile-tools",
        "dbaeumer.vscode-eslint",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestArgs": ["backend/tests"],
        "python.testing.pytestEnabled": true,
        "editor.formatOnSave": true,
        "ruff.nativeServer": true,
        "[python]": {"editor.defaultFormatter": "charliermarsh.ruff"},
        "files.exclude": {
          "**/__pycache__": true,
          "**/.pytest_cache": true,
          "**/.ruff_cache": true,
          "**/.mypy_cache": true
        }
      }
    }
  },
  "remoteEnv": {
    "DEMO_MODE": "true"
  }
}
