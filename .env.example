# --- Copernicus Marine Service credentials (required for live data) ---
# Register at https://data.marine.copernicus.eu/register
# NEVER commit real values here -- this file is a template. Copy to .env
# (which is gitignored) and fill in your own credentials.
COPERNICUSMARINE_SERVICE_USERNAME=your-cms-username
COPERNICUSMARINE_SERVICE_PASSWORD=your-cms-password

# --- Runtime mode ---
# If true, the backend loads the bundled sample NetCDF instead of calling CMS.
# Useful for demos, CI and reviewers without a CMS account.
DEMO_MODE=false

# --- HTTP server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# --- CORS ---
# Comma-separated list of origins allowed to hit /api/*
CORS_ORIGINS=http://localhost:8000,http://localhost:5173

# --- Cache / data directories (inside the container) ---
CACHE_DIR=/data/cache
ZARR_STORE=/data/cache/sst.zarr
# Pre-computed Hobday climatology zarr (built once via scripts/bootstrap_climatology.py)
CLIMATOLOGY_STORE=/data/cache/climatology.zarr

# --- Study area (lon_min, lat_min, lon_max, lat_max) ---
# Mediterranean + Adriatic default
BBOX=-6.0,30.0,36.5,46.0

# --- Climatology reference period ---
CLIM_START=1991
CLIM_END=2020

# --- EMODnet / EEA overlay endpoints ---
EMODNET_AQUACULTURE_WFS=https://ows.emodnet-humanactivities.eu/wfs
EMODNET_SEABED_WFS=https://ows.emodnet-seabedhabitats.eu/emodnet_open_maplibrary/wms
NATURA2000_WFS=https://bio.discomap.eea.europa.eu/arcgis/services/ProtectedSites/Natura2000Sites/MapServer/WFSServer
