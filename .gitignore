# =============================================================
# MHEAT — public repository .gitignore
# Goal: ship the code, nothing else. No planning, no personal,
# no internal-process artefacts.
# =============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.coverage
.coverage.*
coverage.json
htmlcov/
frontend/coverage/
dist/
build/

# --- Node ---
node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Data / cache / local run artefacts ---
data/
cache/
*.zarr/
*.nc
!backend/app/fixtures/*.nc

# --- Env / secrets (never commit) ---
.env
.env.*
!.env.example
frontend/.env.production

# --- Internal planning + agent artefacts (never publish) ---
out/
DCE/
docs/
CHANGELOG.md
SECURITY.md
CITATION.cff
CODE_OF_CONDUCT.md
CONTRIBUTING.md
SUPPORT.md
HOW_TO_RUN.md
mkdocs.yml

# --- Local-only deploy notes (paths reveal home dir) ---
deploy/cloudflare.md
deploy/cloudflared.config.yml

# --- Internal scripts (audit/screenshot/submission helpers) ---
scripts/_*
scripts/build_review_docx.py
scripts/prepare_submission.py
scripts/state_of_play.py
scripts/update_proposal_docx.py
frontend/a6_screenshot.mjs
frontend/e2e/

# --- Anything starting with an underscore at the project root (audit logs etc) ---
/_*

# --- Zenodo metadata (carries author personal info) ---
.zenodo.json

# --- Locally-generated doc helpers ---
docs/_*.txt
docs/_*.json

# --- IDE / OS ---
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# --- Jupyter ---
.ipynb_checkpoints/

# --- Docker ---
.docker/

# --- Anything that might leak (paranoia layer) ---
*.local
.local-cache/
.cache-local/
*.bak
*.orig
*~
