{"openapi":"3.1.0","info":{"title":"MHEAT API","description":"**MHEAT** — Mediterranean marine-heatwave detection & sectoral-impact API.\n\nDetects Mediterranean & Adriatic marine heatwaves on Copernicus Marine SST using the Hobday et al. (2016) method and exposes them as GeoJSON, CSV, a STAC catalog and PNG anomaly rasters for the EDITO platform. Ships with a built-in demo cube so every endpoint works without Copernicus credentials.","contact":{"name":"MHEAT maintainers","url":"https://github.com/your-org/mheat"},"license":{"name":"MIT","url":"https://opensource.org/licenses/MIT"},"version":"0.2.0"},"paths":{"/api/health":{"get":{"tags":["health"],"summary":"Liveness probe","description":"Reports the service version and whether it is running in demo mode.","operationId":"health_api_health_get","responses":{"200":{"description":"200 OK whenever the process is responsive","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HealthResponse"}}}}}}},"/api/readyz":{"get":{"tags":["health"],"summary":"Readiness probe","description":"Reports whether MHEAT is ready to serve **live** Copernicus data. In demo mode this is always ready. In live mode, the response is ``degraded`` until CMS credentials are set via environment.","operationId":"ready_api_readyz_get","responses":{"200":{"description":"Readiness status + cache-path diagnostics","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ReadyResponse"}}}}}}},"/api/events":{"get":{"tags":["events"],"summary":"Detected MHW events as GeoJSON FeatureCollection","description":"Return all MHW events intersecting the optional spatial/temporal filter.\n\nBy default returns space-time clustered events (typically ~5-10 polygons\nfor the 2022 Mediterranean demo). Pass ``raw=true`` to get the underlying\nper-pixel events (typically 50+ small rectangles).","operationId":"list_events_api_events_get","parameters":[{"name":"bbox","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"description":"lon_min,lat_min,lon_max,lat_max","title":"Bbox"},"description":"lon_min,lat_min,lon_max,lat_max"},{"name":"start","in":"query","required":false,"schema":{"anyOf":[{"type":"string","format":"date"},{"type":"null"}],"description":"YYYY-MM-DD","title":"Start"},"description":"YYYY-MM-DD"},{"name":"end","in":"query","required":false,"schema":{"anyOf":[{"type":"string","format":"date"},{"type":"null"}],"description":"YYYY-MM-DD","title":"End"},"description":"YYYY-MM-DD"},{"name":"min_category","in":"query","required":false,"schema":{"type":"integer","maximum":5,"minimum":1,"default":1,"title":"Min Category"}},{"name":"raw","in":"query","required":false,"schema":{"type":"boolean","description":"Return raw per-pixel events instead of clusters","default":false,"title":"Raw"},"description":"Return raw per-pixel events instead of clusters"},{"name":"include_impact","in":"query","required":false,"schema":{"type":"boolean","description":"Attach per-event impact metrics","default":true,"title":"Include Impact"},"description":"Attach per-event impact metrics"}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/EventCollection"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/events.csv":{"get":{"tags":["events"],"summary":"Detected MHW events as a CSV download","description":"Streams the same event catalog as ``/api/events`` but formatted as CSV (event_id, dates, intensities, category, impact metrics) for direct download into Excel / R / pandas.","operationId":"list_events_csv_api_events_csv_get","parameters":[{"name":"bbox","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"description":"lon_min,lat_min,lon_max,lat_max","title":"Bbox"},"description":"lon_min,lat_min,lon_max,lat_max"},{"name":"start","in":"query","required":false,"schema":{"anyOf":[{"type":"string","format":"date"},{"type":"null"}],"description":"YYYY-MM-DD","title":"Start"},"description":"YYYY-MM-DD"},{"name":"end","in":"query","required":false,"schema":{"anyOf":[{"type":"string","format":"date"},{"type":"null"}],"description":"YYYY-MM-DD","title":"End"},"description":"YYYY-MM-DD"},{"name":"min_category","in":"query","required":false,"schema":{"type":"integer","maximum":5,"minimum":1,"default":1,"title":"Min Category"}},{"name":"raw","in":"query","required":false,"schema":{"type":"boolean","description":"Return raw per-pixel events instead of clusters","default":false,"title":"Raw"},"description":"Return raw per-pixel events instead of clusters"}],"responses":{"200":{"description":"CSV file (text/csv) with one row per event","content":{"application/json":{"schema":{}},"text/csv":{}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/events/{event_id}/series":{"get":{"tags":["events"],"summary":"SST, climatology & threshold time-series around an event","description":"Returns a short SST / climatology / 90th-percentile-threshold window around a single event at the given location. Used by the UI to draw a Hobday-style diagnostic chart in the event detail panel.","operationId":"event_series_api_events__event_id__series_get","parameters":[{"name":"event_id","in":"path","required":true,"schema":{"type":"string","title":"Event Id"}},{"name":"lon","in":"query","required":true,"schema":{"type":"number","description":"Longitude in decimal degrees","title":"Lon"},"description":"Longitude in decimal degrees"},{"name":"lat","in":"query","required":true,"schema":{"type":"number","description":"Latitude in decimal degrees","title":"Lat"},"description":"Latitude in decimal degrees"},{"name":"pad_days","in":"query","required":false,"schema":{"type":"integer","maximum":120,"minimum":1,"description":"Days to pad around the event","default":30,"title":"Pad Days"},"description":"Days to pad around the event"},{"name":"start","in":"query","required":false,"schema":{"anyOf":[{"type":"string","format":"date"},{"type":"null"}],"title":"Start"}},{"name":"end","in":"query","required":false,"schema":{"anyOf":[{"type":"string","format":"date"},{"type":"null"}],"title":"End"}}],"responses":{"200":{"description":"JSON with parallel arrays: time, sst, clim, threshold","content":{"application/json":{"schema":{"type":"object","title":"Response Event Series Api Events  Event Id  Series Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/processes":{"get":{"tags":["processes"],"summary":"List available processes","description":"OGC-API-Processes style listing of the computation jobs MHEAT exposes.","operationId":"list_processes_api_processes_get","responses":{"200":{"description":"Array of process descriptors","content":{"application/json":{"schema":{"type":"object","title":"Response List Processes Api Processes Get"}}}}}}},"/api/processes/mhw-detect":{"post":{"tags":["processes"],"summary":"Run MHW detection on the configured SST cube","description":"Runs the Hobday 2016 pixel-wise detector on the configured SST cube for an optional bbox and temporal window, then joins the detected events with the sectoral overlays (`with_impact=true`).","operationId":"mhw_detect_api_processes_mhw_detect_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/DetectInputs"}}},"required":true},"responses":{"200":{"description":"Envelope with per-event GeoJSON + optional impact summary","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DetectResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/overlays":{"get":{"tags":["overlays"],"summary":"List supported overlay kinds","description":"Enumerates the sectoral overlays available through `/api/overlays/{kind}`.","operationId":"list_kinds_api_overlays_get","responses":{"200":{"description":"List of overlay identifiers","content":{"application/json":{"schema":{"type":"object","title":"Response List Kinds Api Overlays Get"}}}}}}},"/api/overlays/{kind}":{"get":{"tags":["overlays"],"summary":"Fetch an overlay as GeoJSON","description":"Returns a GeoJSON FeatureCollection for one of the sectoral overlays (`aquaculture`, `mpa`, `seagrass`). Geometries are pre-fetched from EMODnet / EEA WFS and cached locally.","operationId":"get_overlay_api_overlays__kind__get","parameters":[{"name":"kind","in":"path","required":true,"schema":{"type":"string","title":"Kind"}}],"responses":{"200":{"description":"GeoJSON FeatureCollection","content":{"application/json":{"schema":{"type":"object","title":"Response Get Overlay Api Overlays  Kind  Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/stac/collections":{"get":{"tags":["stac"],"summary":"List STAC collections","description":"STAC Collections endpoint — enumerates every collection MHEAT publishes.","operationId":"collections_api_stac_collections_get","responses":{"200":{"description":"STAC-style JSON with a `collections` array","content":{"application/json":{"schema":{"type":"object","title":"Response Collections Api Stac Collections Get"}}}}}}},"/api/stac/collections/{collection_id}":{"get":{"tags":["stac"],"summary":"Get one STAC collection","description":"Fetch the metadata document for a single STAC collection.","operationId":"get_collection_api_stac_collections__collection_id__get","parameters":[{"name":"collection_id","in":"path","required":true,"schema":{"type":"string","title":"Collection Id"}}],"responses":{"200":{"description":"STAC Collection object","content":{"application/json":{"schema":{"type":"object","title":"Response Get Collection Api Stac Collections  Collection Id  Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/stac/collections/{collection_id}/items":{"get":{"tags":["stac"],"summary":"List items in a collection","description":"Returns a STAC ItemCollection (GeoJSON FeatureCollection with STAC properties).","operationId":"list_items_api_stac_collections__collection_id__items_get","parameters":[{"name":"collection_id","in":"path","required":true,"schema":{"type":"string","title":"Collection Id"}}],"responses":{"200":{"description":"STAC ItemCollection","content":{"application/json":{"schema":{"type":"object","title":"Response List Items Api Stac Collections  Collection Id  Items Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/stac/collections/{collection_id}/items/{item_id}":{"get":{"tags":["stac"],"summary":"Get one STAC item","description":"Fetch a single STAC Item by id.","operationId":"get_item_api_stac_collections__collection_id__items__item_id__get","parameters":[{"name":"collection_id","in":"path","required":true,"schema":{"type":"string","title":"Collection Id"}},{"name":"item_id","in":"path","required":true,"schema":{"type":"string","title":"Item Id"}}],"responses":{"200":{"description":"STAC Item (GeoJSON Feature with STAC properties)","content":{"application/json":{"schema":{"type":"object","title":"Response Get Item Api Stac Collections  Collection Id  Items  Item Id  Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/anomaly":{"get":{"tags":["anomaly"],"summary":"SST anomaly PNG tile for a given date","description":"Returns a PNG image of the SST anomaly (observation minus DOY climatology) for the requested date. Served with a long-lived ``Cache-Control: immutable`` header plus an ETag so the client never needs to re-download the same tile.","operationId":"anomaly_png_api_anomaly_get","parameters":[{"name":"date","in":"query","required":true,"schema":{"type":"string","format":"date","description":"YYYY-MM-DD","title":"Date"},"description":"YYYY-MM-DD"},{"name":"bbox","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"description":"Reserved; bbox currently ignored in demo mode","title":"Bbox"},"description":"Reserved; bbox currently ignored in demo mode"},{"name":"If-None-Match","in":"header","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"If-None-Match"}}],"responses":{"200":{"description":"PNG image (image/png) with ETag and Cache-Control headers","content":{"application/json":{"schema":{}},"image/png":{}}},"304":{"description":"Not modified (ETag matched)"},"404":{"description":"Date out of range"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/anomaly/extent":{"get":{"tags":["anomaly"],"summary":"Temporal extent covered by the anomaly endpoint","description":"Returns the date range the anomaly endpoint can serve.","operationId":"anomaly_extent_api_anomaly_extent_get","responses":{"200":{"description":"First & last available date plus colour-scale range","content":{"application/json":{"schema":{"type":"object","title":"Response Anomaly Extent Api Anomaly Extent Get"}}}}}}},"/api/ogcapi":{"get":{"tags":["ogcapi"],"summary":"OGC API Features landing page","description":"Entry point exposing links to conformance, collections, and API docs.","operationId":"landing_api_ogcapi_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","title":"Response Landing Api Ogcapi Get"}}}}}}},"/api/ogcapi/conformance":{"get":{"tags":["ogcapi"],"summary":"OGC API Features conformance classes","description":"Lists the OGC API Features conformance classes implemented by this service.","operationId":"conformance_api_ogcapi_conformance_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","title":"Response Conformance Api Ogcapi Conformance Get"}}}}}}},"/api/ogcapi/collections":{"get":{"tags":["ogcapi"],"summary":"List OGC API feature collections","description":"Enumerates all OGC API feature collections (events, aquaculture, mpa, seagrass).","operationId":"list_collections_api_ogcapi_collections_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","title":"Response List Collections Api Ogcapi Collections Get"}}}}}}},"/api/ogcapi/collections/{collection_id}":{"get":{"tags":["ogcapi"],"summary":"Fetch OGC collection metadata","description":"Returns metadata (title, description, extent, CRS) for a single collection.","operationId":"get_collection_api_ogcapi_collections__collection_id__get","parameters":[{"name":"collection_id","in":"path","required":true,"schema":{"type":"string","title":"Collection Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","title":"Response Get Collection Api Ogcapi Collections  Collection Id  Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/ogcapi/collections/{collection_id}/items":{"get":{"tags":["ogcapi"],"summary":"List features (paged)","description":"Returns a paged GeoJSON FeatureCollection. Supports ``bbox``, ``datetime``, ``limit`` (max 1000) and ``offset``. A ``next`` link header is emitted when more features are available.","operationId":"list_items_api_ogcapi_collections__collection_id__items_get","parameters":[{"name":"collection_id","in":"path","required":true,"schema":{"type":"string","title":"Collection Id"}},{"name":"bbox","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"description":"lon_min,lat_min,lon_max,lat_max","title":"Bbox"},"description":"lon_min,lat_min,lon_max,lat_max"},{"name":"datetime","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"description":"RFC3339 instant or interval","title":"Datetime"},"description":"RFC3339 instant or interval"},{"name":"limit","in":"query","required":false,"schema":{"type":"integer","maximum":1000,"minimum":1,"default":100,"title":"Limit"}},{"name":"offset","in":"query","required":false,"schema":{"type":"integer","minimum":0,"default":0,"title":"Offset"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/ogcapi/collections/{collection_id}/items/{feature_id}":{"get":{"tags":["ogcapi"],"summary":"Fetch a single feature","description":"Retrieve one feature from a collection by its ``id``.","operationId":"get_item_api_ogcapi_collections__collection_id__items__feature_id__get","parameters":[{"name":"collection_id","in":"path","required":true,"schema":{"type":"string","title":"Collection Id"}},{"name":"feature_id","in":"path","required":true,"schema":{"type":"string","title":"Feature Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","title":"Response Get Item Api Ogcapi Collections  Collection Id  Items  Feature Id  Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}}},"components":{"schemas":{"DetectInputs":{"properties":{"bbox":{"anyOf":[{"items":{"type":"number"},"type":"array","maxItems":4,"minItems":4},{"type":"null"}],"title":"Bbox","description":"[lon_min, lat_min, lon_max, lat_max]"},"start":{"anyOf":[{"type":"string","format":"date"},{"type":"null"}],"title":"Start"},"end":{"anyOf":[{"type":"string","format":"date"},{"type":"null"}],"title":"End"},"min_category":{"type":"integer","maximum":5.0,"minimum":1.0,"title":"Min Category","default":1},"with_impact":{"type":"boolean","title":"With Impact","description":"Compute overlay intersections","default":true}},"type":"object","title":"DetectInputs","description":"Input payload for the mhw-detect process."},"DetectResponse":{"properties":{"status":{"type":"string","title":"Status"},"n_events":{"type":"integer","title":"N Events"},"events":{"type":"object","title":"Events"},"impact":{"anyOf":[{"type":"object"},{"type":"null"}],"title":"Impact"}},"type":"object","required":["status","n_events","events"],"title":"DetectResponse","description":"Response envelope for the mhw-detect process."},"EventCollection":{"properties":{"type":{"type":"string","title":"Type","default":"FeatureCollection"},"features":{"items":{"$ref":"#/components/schemas/EventFeature"},"type":"array","title":"Features"}},"type":"object","required":["features"],"title":"EventCollection"},"EventFeature":{"properties":{"type":{"type":"string","title":"Type","default":"Feature"},"id":{"type":"string","title":"Id"},"geometry":{"type":"object","title":"Geometry"},"properties":{"$ref":"#/components/schemas/EventProperties"}},"type":"object","required":["id","geometry","properties"],"title":"EventFeature"},"EventProperties":{"properties":{"event_id":{"type":"string","title":"Event Id"},"date_start":{"type":"string","title":"Date Start"},"date_end":{"type":"string","title":"Date End"},"date_peak":{"type":"string","title":"Date Peak"},"duration_days":{"type":"integer","title":"Duration Days"},"intensity_max":{"type":"number","title":"Intensity Max"},"intensity_mean":{"type":"number","title":"Intensity Mean"},"intensity_cumulative":{"type":"number","title":"Intensity Cumulative"},"category":{"type":"integer","title":"Category"},"category_name":{"type":"string","title":"Category Name"},"n_pixels":{"type":"integer","title":"N Pixels","default":1},"centroid":{"items":{"type":"number"},"type":"array","title":"Centroid"},"impact":{"anyOf":[{"type":"object"},{"type":"null"}],"title":"Impact"}},"type":"object","required":["event_id","date_start","date_end","date_peak","duration_days","intensity_max","intensity_mean","intensity_cumulative","category","category_name","centroid"],"title":"EventProperties"},"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"HealthResponse":{"properties":{"status":{"type":"string","title":"Status"},"version":{"type":"string","title":"Version"},"demo_mode":{"type":"boolean","title":"Demo Mode"}},"type":"object","required":["status","version","demo_mode"],"title":"HealthResponse","description":"Basic liveness response."},"ReadyResponse":{"properties":{"status":{"type":"string","title":"Status"},"demo_mode":{"type":"boolean","title":"Demo Mode"},"cms_credentials":{"type":"boolean","title":"Cms Credentials"},"cache_dir":{"type":"string","title":"Cache Dir"},"zarr_store":{"type":"string","title":"Zarr Store"}},"type":"object","required":["status","demo_mode","cms_credentials","cache_dir","zarr_store"],"title":"ReadyResponse","description":"Readiness response — reports whether CMS credentials are wired up."},"ValidationError":{"properties":{"loc":{"items":{"anyOf":[{"type":"string"},{"type":"integer"}]},"type":"array","title":"Location"},"msg":{"type":"string","title":"Message"},"type":{"type":"string","title":"Error Type"}},"type":"object","required":["loc","msg","type"],"title":"ValidationError"}}},"tags":[{"name":"health","description":"Liveness and readiness probes suitable for Kubernetes."},{"name":"events","description":"Detected marine heatwave events as GeoJSON (clustered or raw) and as CSV, plus per-event time-series diagnostics."},{"name":"overlays","description":"Sectoral GeoJSON overlays: aquaculture sites, MPAs, seagrass beds."},{"name":"stac","description":"STAC catalog describing the MHEAT output artefacts."},{"name":"anomaly","description":"PNG rasters of the SST anomaly for a given date."},{"name":"processes","description":"OGC-API-Processes-style compute endpoints."},{"name":"ogcapi","description":"OGC API — Features 1.0 endpoints (QGIS/ArcGIS-compatible)."}]}